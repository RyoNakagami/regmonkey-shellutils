# .editorconfig

# set the root of the project
root = true

# set default charset, line endings, and whitespace rules
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

# shell scripts
[*.sh]
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

# markdown files
[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

# csv files
[*.csv]
trim_trailing_whitespace = false
insert_final_newline = true
end_of_line = lf

# json files
[*.json]
indent_style = space
indent_size = 2
insert_final_newline = true
end_of_line = lf
trim_trailing_whitespace = false

# yaml files
[{*.yml,*.yaml}]
indent_style = space
indent_size = 2
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
